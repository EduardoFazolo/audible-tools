{
  "manifest_version": 3,
  "name": "Audible Tools",
  "description": "Utility controls for Audible with persistent settings and in-page volume boost.",
  "version": "1.0.0",
  "icons": {
    "16": "icon/icon16.png",
    "32": "icon/icon32.png",
    "48": "icon/icon48.png",
    "128": "icon/icon128.png"
  },
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://audible.com/*",
    "https://*.audible.com/*",
    "https://audible.com.br/*",
    "https://*.audible.com.br/*",
    "https://audible.co.uk/*",
    "https://*.audible.co.uk/*",
    "https://audible.de/*",
    "https://*.audible.de/*",
    "https://audible.fr/*",
    "https://*.audible.fr/*",
    "https://audible.com.au/*",
    "https://*.audible.com.au/*",
    "https://audible.in/*",
    "https://*.audible.in/*",
    "https://audible.ca/*",
    "https://*.audible.ca/*",
    "https://audible.co.jp/*",
    "https://*.audible.co.jp/*",
    "https://audible.it/*",
    "https://*.audible.it/*",
    "https://audible.es/*",
    "https://*.audible.es/*"
  ],
  "action": {
    "default_title": "Audible Tools",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icon/icon16.png",
      "32": "icon/icon32.png",
      "48": "icon/icon48.png",
      "128": "icon/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://audible.com/*",
        "https://*.audible.com/*",
        "https://audible.com.br/*",
        "https://*.audible.com.br/*",
        "https://audible.co.uk/*",
        "https://*.audible.co.uk/*",
        "https://audible.de/*",
        "https://*.audible.de/*",
        "https://audible.fr/*",
        "https://*.audible.fr/*",
        "https://audible.com.au/*",
        "https://*.audible.com.au/*",
        "https://audible.in/*",
        "https://*.audible.in/*",
        "https://audible.ca/*",
        "https://*.audible.ca/*",
        "https://audible.co.jp/*",
        "https://*.audible.co.jp/*",
        "https://audible.it/*",
        "https://*.audible.it/*",
        "https://audible.es/*",
        "https://*.audible.es/*"
      ],
      "js": [
        "content/audible.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "assets/*.svg"
      ],
      "matches": [
        "https://audible.com/*",
        "https://*.audible.com/*",
        "https://audible.com.br/*",
        "https://*.audible.com.br/*",
        "https://audible.co.uk/*",
        "https://*.audible.co.uk/*",
        "https://audible.de/*",
        "https://*.audible.de/*",
        "https://audible.fr/*",
        "https://*.audible.fr/*",
        "https://audible.com.au/*",
        "https://*.audible.com.au/*",
        "https://audible.in/*",
        "https://*.audible.in/*",
        "https://audible.ca/*",
        "https://*.audible.ca/*",
        "https://audible.co.jp/*",
        "https://*.audible.co.jp/*",
        "https://audible.it/*",
        "https://*.audible.it/*",
        "https://audible.es/*",
        "https://*.audible.es/*"
      ]
    }
  ]
}
